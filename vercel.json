{
    "headers": [
        {
            "source": "/files/(.*\\.pdf)",
            "headers": [
                { "key": "Content-Desposition", "value": "attachment"},
                { "key": "Content-Type", "value": "application/pdf"},
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutabel"}
            ]
        }
    ]
}